# PostgreSQL connection string for backend FastAPI
# - If PostgreSQL runs on the Docker host: use host.docker.internal
# - If PostgreSQL runs in another container on a shared Docker network: use that container/service name
DATABASE_URL=postgresql://postgres:password@host.docker.internal:5432/postgres

# Security settings for JWT login
SECRET_KEY=change-me-to-a-long-random-secret
MASTER_PASSWORD=your_secure_master_password

# OpenAI API key for ASK feature
KEY_OPENAI=sk-your-openai-api-key

# Optional: comma-separated table names to ignore when auto-detecting account tables
ACCOUNT_IGNORE_TABLES=

# Optional: cache TTL (seconds) for account table list lookup
ACCOUNT_TABLE_CACHE_TTL_SECONDS=30
