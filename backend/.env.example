# PostgreSQL connection string for backend FastAPI
# - Recommended (same Docker network): use postgres_account
# - If PostgreSQL runs on host instead: use host.docker.internal
DATABASE_URL=postgresql://postgres:password@postgres_account:5432/postgres

# Security settings for JWT login
SECRET_KEY=change-me-to-a-long-random-secret
MASTER_PASSWORD=your_secure_master_password
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# OpenAI API key for ASK feature
KEY_OPENAI=sk-your-openai-api-key

# Timezone used for day/month boundary calculations in normalized summaries
APP_TIMEZONE=Asia/Seoul

# Optional: cache TTL (seconds) for normalized account metadata lookup
ACCOUNT_TABLE_CACHE_TTL_SECONDS=30
